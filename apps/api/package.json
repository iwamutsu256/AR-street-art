{
  "name": "@street-art/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "redis:test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.879.0",
    "@hono/node-server": "^1.19.5",
    "@street-art/shared": "workspace:*",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.9.7",
    "ioredis": "^5.7.0",
    "postgres": "^3.4.7",
    "sharp": "^0.34.3",
    "ws": "^8.20.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.4",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
