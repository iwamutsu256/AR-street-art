# Common
NODE_ENV=development

# Frontend
NEXT_PUBLIC_MAPTILER_KEY=replace_me
NEXT_PUBLIC_API_BASE=/api
NEXT_PUBLIC_WS_BASE=/ws
API_PROXY_TARGET=http://localhost:3001
FRONTEND_DEV_HTTPS=0
FRONTEND_DEV_HOST=localhost

# Admin (port 3002)
ADMIN_PASSWORD=replace_me_with_a_strong_password
ADMIN_SESSION_SECRET=replace_me_with_a_long_random_string
INTERNAL_API_URL=http://localhost:3001

# API
API_PORT=3001
APP_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/street_art
REDIS_URL=redis://redis:6379
SESSION_SECRET=replace_me_with_a_long_random_string
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
